# Frontend environment variables
# Copy to .env and fill in production values.

# Optional: Override the server hostname (defaults to OS hostname)
# SERVER_HOSTNAME=your-domain.com

# Backend hostname (Docker internal DNS name)
BACKEND_HOSTNAME=backend

# Optional: Override backend port (defaults to 80)
# BACKEND_PORT=80

# Disable mocks and enable proxy mode for production
USE_MOCK=false
USE_PROXY=true

# Must be 0 (false) in production
DEV=0

# ── Smart Defaults (no need to set these) ──
# SERVER_HOSTNAME — defaults to socket.gethostname()
# SESSION_COOKIE_NAME — auto-computed as "{SERVER_HOSTNAME}.session"
# API_BASE (client-side) — auto-set based on PROXY/MOCK mode
# BACKEND_URL — auto-constructed as "http://{BACKEND_HOSTNAME}:{BACKEND_PORT}"


