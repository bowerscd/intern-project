# Frontend environment variables
# Copy to .env and fill in production values.

# Backend URL (internal Docker network address)
API_BASE=http://backend:8000

# Disable mocks and enable proxy mode for production
USE_MOCK=false
USE_PROXY=true

# Must be 0 (false) in production
DEV=0

# Must match the backend's SESSION_COOKIE_NAME: f"{SERVER_HOSTNAME}.session"
SESSION_COOKIE_NAME=yourdomain.com.session
