{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": "src/ts",
    "outDir": "static/dist"
  },
  "include": ["src/ts/**/*.ts"],
  "exclude": ["src/ts/**/*.test.ts"]
}
