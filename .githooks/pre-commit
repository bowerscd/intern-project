#!/usr/bin/env bash
# Pre-commit hook — lint + test gate for AI-generated commits.
#
# Delegates entirely to Makefile targets so hook and CI stay in sync:
#   make lint-backend    make lint-frontend
#   make test-backend    make test-frontend
#
# Bypass:  git commit --no-verify
# Skip tests only:  SKIP_TESTS=1 git commit

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

BACKEND_PY="$ROOT/backend/.venv/bin/python"
FRONTEND_PY="$ROOT/frontend/.venv/bin/python"

# ── Preflight ─────────────────────────────────────────────────────────────────

if [ ! -x "$BACKEND_PY" ] || [ ! -x "$FRONTEND_PY" ]; then
    echo "⚠  Venvs not found. Run 'make setup' first."
    exit 1
fi

FAILED=0

run_step() {
    local label="$1"
    shift
    printf "  %-40s" "$label"
    if "$@" > /dev/null 2>&1; then
        printf "\033[32m✔\033[0m\n"
    else
        printf "\033[31m✘\033[0m\n"
        FAILED=1
    fi
}

echo "pre-commit: running checks…"

# ── Lint ──────────────────────────────────────────────────────────────────────

run_step "lint backend"       make -C "$ROOT" lint-backend
run_step "lint frontend"      make -C "$ROOT" lint-frontend

# ── Tests (skip with SKIP_TESTS=1) ───────────────────────────────────────────

if [ "${SKIP_TESTS:-0}" = "1" ]; then
    echo "  (tests skipped — SKIP_TESTS=1)"
else
    run_step "test backend"   make -C "$ROOT" test-backend
    run_step "test frontend"  make -C "$ROOT" test-frontend
fi

# ── Result ────────────────────────────────────────────────────────────────────

if [ "$FAILED" -ne 0 ]; then
    echo ""
    echo "pre-commit: \033[31mone or more checks failed.\033[0m Fix and retry, or bypass with --no-verify."
    exit 1
fi

echo "pre-commit: \033[32mall checks passed.\033[0m"
