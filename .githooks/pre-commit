#!/usr/bin/env bash
# Pre-commit hook — lint + test gate for AI-generated commits.
#
# Runs:  ruff check (backend + frontend)
#        tsc --noEmit (frontend TypeScript)
#        pytest backend
#        pytest frontend (Python)
#        vitest (frontend TypeScript)
#
# Bypass:  git commit --no-verify
# Skip tests only:  SKIP_TESTS=1 git commit

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

BACKEND_PY="$ROOT/backend/.venv/bin/python"
FRONTEND_PY="$ROOT/frontend/.venv/bin/python"

# ── Preflight ─────────────────────────────────────────────────────────────────

if [ ! -x "$BACKEND_PY" ] || [ ! -x "$FRONTEND_PY" ]; then
    echo "⚠  Venvs not found. Run 'make setup' first."
    exit 1
fi

FAILED=0

run_step() {
    local label="$1"
    shift
    printf "  %-40s" "$label"
    if "$@" > /dev/null 2>&1; then
        printf "\033[32m✔\033[0m\n"
    else
        printf "\033[31m✘\033[0m\n"
        FAILED=1
    fi
}

run_step_in() {
    local label="$1"
    local dir="$2"
    shift 2
    printf "  %-40s" "$label"
    if (cd "$dir" && "$@" > /dev/null 2>&1); then
        printf "\033[32m✔\033[0m\n"
    else
        printf "\033[31m✘\033[0m\n"
        FAILED=1
    fi
}

echo "pre-commit: running checks…"

# ── Lint ──────────────────────────────────────────────────────────────────────

run_step "ruff check backend"      "$BACKEND_PY"  -m ruff check "$ROOT/backend"
run_step "ruff check frontend"     "$FRONTEND_PY" -m ruff check "$ROOT/frontend"
run_step "tsc --noEmit frontend"   npx --prefix "$ROOT/frontend" tsc -p "$ROOT/frontend/tsconfig.json" --noEmit

# ── Tests (skip with SKIP_TESTS=1) ───────────────────────────────────────────

if [ "${SKIP_TESTS:-0}" = "1" ]; then
    echo "  (tests skipped — SKIP_TESTS=1)"
else
    run_step_in "pytest backend"  "$ROOT/backend"  "$BACKEND_PY"  -m pytest tests/ -x -q --import-mode=importlib --no-header --tb=line
    run_step_in "pytest frontend" "$ROOT/frontend" "$FRONTEND_PY" -m pytest tests/ -x -q --no-header --tb=line
    run_step_in "vitest frontend" "$ROOT/frontend" npx vitest run --reporter=dot 2>&1
fi

# ── Result ────────────────────────────────────────────────────────────────────

if [ "$FAILED" -ne 0 ]; then
    echo ""
    echo "pre-commit: \033[31mone or more checks failed.\033[0m Fix and retry, or bypass with --no-verify."
    exit 1
fi

echo "pre-commit: \033[32mall checks passed.\033[0m"
