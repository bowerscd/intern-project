# Backend environment variables
# Copy to .env and fill in production values.

# Core
DEV=0
SERVER_HOSTNAME=yourdomain.com
SESSION_SECRET=<generate-a-strong-random-secret>
DATABASE_URI=sqlite:///data/app.db
LOG_LEVEL=INFO

# Session cookies
SESSION_COOKIE_DOMAIN=.yourdomain.com
SESSION_SAME_SITE=lax

# CORS — JSON array of allowed origins
CORS_ALLOW_ORIGINS=["https://sites.yourdomain.com"]

# OIDC — Google provider
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_REDIRECT_URI=https://sites.yourdomain.com/api/v2/auth/callback/google

# SMTP (optional — required for notifications)
# SMTP_URI=smtp://user:pass@smtp.example.com:587
# MAIL_SENDER=noreply@yourdomain.com

# Auth redirect origins — JSON array of allowed absolute redirect targets
# AUTH_REDIRECT_ORIGINS=["https://sites.yourdomain.com"]

# Scheduler (set to 0 to disable background jobs, e.g. in multi-instance deploys)
# SCHEDULER_ENABLED=1

# Uvicorn trusted proxy IPs (used in Dockerfile CMD, comma-separated)
# FORWARDED_ALLOW_IPS=127.0.0.1
